#[path = "../common/mod.rs"]
mod common;

use std::fs::File;
use std::net::TcpStream;
use std::io::{BufRead, BufReader, Write};
use std::thread;
use std::time::Duration;
use libc::{shm_open, shm_unlink, mmap, ftruncate, munmap, close, O_CREAT, O_RDWR, PROT_READ, PROT_WRITE, MAP_SHARED, S_IRUSR, S_IWUSR};
use std::os::unix::io::RawFd;

use common::{config::CLMGR_CONFIG_PATH, utils::Utils};
use crate::common::api_commands::MetricsCommand;

const SHM_NAME: &str = "/my_shared_memory";
const SHM_SIZE: usize = 4096;

enum CommandType {
    Start { pid: u32, upper_threshold: u32, lower_threshold: u32, interval: u64 },
    Log { pid: u32, metrics: String },
    Stop { pid: u32 },
}

pub struct Metrics;

const UPSCALE_FACTOR: u32 = 40;
const DOWNSCALE_FACTOR: u32 = 20;

impl Metrics {
        pub fn get_metrics_mgr_address() -> (String, u16) {
            let config = Utils::load_config_file(CLMGR_CONFIG_PATH);

            (config["resource-manager"]["address"].as_str().unwrap().to_string(), config["resource-manager"]["metrics-port"].as_integer().unwrap() as u16)
        }

        pub fn get_log_filepath() -> String {
            let config = Utils::load_config_file(CLMGR_CONFIG_PATH);

            return config["resource-metrics"]["log-file"].as_str().unwrap().to_string();
        }

        pub fn get_metric_threshold() -> (u16, u16, u16) {
            let config = Utils::load_config_file(CLMGR_CONFIG_PATH);

            (config["resource-metrics"]["upper-limit"].as_integer().unwrap() as u16, config["resource-metrics"]["lower-limit"].as_integer().unwrap() as u16, config["resource-metrics"]["metric-interval"].as_integer().unwrap() as u16)
        }


        // Function to adjust resources based on the condition
        fn send_scale_command(scalevalue: u32, upscale: bool, address: &String) -> bool {

            let stream = TcpStream::connect(address);

            let mut stream = match stream {
                Ok(stream) => stream,
                Err(error) => {
                    log::error!("Error connecting to server: {}", error);
                    return false; // Exit the function if connection fails
                }
            };

            let cmd = if upscale { 
                MetricsCommand::CLIENTD_MMGR_UPSCALE
            } else {
                MetricsCommand::CLIENTD_MMGR_DOWNSCALE
            };
            let message = format!( "{}\n{}\n", cmd, scalevalue);

            if let Err(e) = stream.write_all(message.as_bytes()) {
                log::error!("Error writing to stream: {}", e);
                return false;
            }

            log::debug!("Scaling resource upscale: {}, scalevalue: {}", upscale, scalevalue);
            true
        }

        fn parse_command(line: &str) -> Option<CommandType> {
            let parts: Vec<&str> = line.split_whitespace().collect();
            match parts.as_slice() {
                ["START", pid, upper, lower, interval] => Some(CommandType::Start {
                    pid: pid.parse().ok()?,
                    upper_threshold: upper.parse().ok()?,
                    lower_threshold: lower.parse().ok()?,
                    interval: interval.parse().ok()?,
                }),
                ["LOG", pid, metrics] => Some(CommandType::Log {
                    pid: pid.parse().ok()?,
                    metrics: metrics.to_string(),
                }),
                ["STOP", pid] => Some(CommandType::Stop {
                    pid: pid.parse().ok()?,
                }),
                _ => None,
            }
        }

        fn read_from_shared_memory(reader: BufReader, default_interval: Duration) {
            let file = OpenOptions::new().read(true).open(file_path).expect("Cannot open file");
            let reader = BufReader::new(file);

            let mut pids: Vec<u32> = Vec::new();
            let mut last_read_time = Instant::now();

            for line in reader.lines() {
                if let Ok(line) = line {
                    if let Some(command) = parse_command(&line) {
                        match command {
                            CommandType::Start { pid, upper_threshold, lower_threshold, interval } => {
                                println!("START Command: PID={}, Upper={}, Lower={}, Interval={}", pid, upper_threshold, lower_threshold, interval);
                                pids.push(pid);
                                // Do something with the thresholds and interval
                            },
                            CommandType::Log { pid, metrics } => {
                                println!("LOG Command: PID={}, Metrics={}", pid, metrics);
                                // Handle the log metrics for the PID
                            },
                            CommandType::Stop { pid } => {
                                println!("STOP Command: PID={}", pid);
                                pids.retain(|&p| p != pid);
                            },
                        }
                    }
                }
            }
        }

                // Sleep until the next PID needs to be read or for the default interval
                let sleep_duration = if pids.is_empty() {
                    default_interval
                } else {
                    let elapsed = last_read_time.elapsed();
                    if elapsed >= default_interval {
                        default_interval
                    } else {
                        default_interval - elapsed
                    }
                };
                sleep(sleep_duration);
                last_read_time = Instant::now();
            }
        }

        // Function to monitor response times
        pub fn monitor_response_time() {
            let (resource_manager_address, resource_manager_port) = Metrics::get_metrics_mgr_address();
            let (upper_threshold, lower_threshold, interval_secs) = Metrics::get_metric_threshold();

            let file_path = Metrics::get_log_filepath();
            let file = File::open(file_path).expect("Could not open response_time.log");
            let mut reader = BufReader::new(file);

            // Connect to the server once before the loop
            let address = format!("{}:{}", resource_manager_address, resource_manager_port);

            loop {
                let mut times = Vec::new();

                // Read new lines from the file
                let mut line = String::new();
                while reader.read_line(&mut line).unwrap_or(0) > 0 {
                    let trimmed_line = line.trim();
                    if let Ok(time) = trimmed_line.parse::<f64>() {
                        times.push(time);
                    }
                    line.clear(); // Clear the line buffer for the next line
                }

                if !times.is_empty() {
                    let sum: f64 = times.iter().sum();
                    let avg_time = sum / times.len() as f64;

                    // Use the cloned stream here
                    if avg_time > upper_threshold as f64 {
                        Metrics::send_scale_command(UPSCALE_FACTOR, true, &address);
                    } else if avg_time < lower_threshold as f64 {
                        Metrics::send_scale_command(DOWNSCALE_FACTOR, false, &address);
                    }
                }

                thread::sleep(Duration::from_secs(interval_secs as u64));
            }
        }

}

