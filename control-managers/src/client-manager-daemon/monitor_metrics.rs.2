use std::sync::{Arc, Mutex};
use std::thread;
use std::time::Duration;

#[derive(Debug, Clone)]
struct FunctionData {
    name: String,
    upper_threshold: f64,
    lower_threshold: f64,
    spike_count: usize,
    metrics: Vec<f64>,
}

#[derive(Debug)]
struct PIDData {
    functions: HashMap<String, FunctionData>,
    read_interval: u64,
    last_read_time: Instant,
}

struct MetricsHandler {
    pids: Arc<Mutex<HashMap<u32, PIDData>>>,
    default_time_interval: u64,
    shared_memory_path: String,
}

impl MetricsHandler {
    pub fn new(default_interval: u64) -> Self {
        MetricsHandler {
            pids: Arc::new(Mutex::new(HashMap::new())),
            default_interval,
            shared_memory_path,
        }
    }
    pub fn get_metrics_mgr_address() -> (String, u16) {
        let config = Utils::load_config_file(CLMGR_CONFIG_PATH);

        (config["resource-manager"]["address"].as_str().unwrap().to_string(), config["resource-manager"]["metrics-port"].as_integer().unwrap() as u16)
    }

    pub fn get_log_filepath() -> String {
        let config = Utils::load_config_file(CLMGR_CONFIG_PATH);

        return config["resource-metrics"]["log-file"].as_str().unwrap().to_string();
    }

    pub fn get_metric_threshold() -> (u16, u16, u16) {
        let config = Utils::load_config_file(CLMGR_CONFIG_PATH);

        (config["resource-metrics"]["upper-limit"].as_integer().unwrap() as u16, config["resource-metrics"]["lower-limit"].as_integer().unwrap() as u16, config["resource-metrics"]["metric-interval"].as_integer().unwrap() as u16)
    }


    // Function to adjust resources based on the condition
    fn send_scale_command(&self, scalevalue: u32, upscale: bool, address: &String) -> bool {

        let stream = TcpStream::connect(address);

        let mut stream = match stream {
            Ok(stream) => stream,
            Err(error) => {
                log::error!("Error connecting to server: {}", error);
                return false; // Exit the function if connection fails
            }
        };

        let cmd = if upscale { 
            MetricsCommand::CLIENTD_MMGR_UPSCALE
        } else {
            MetricsCommand::CLIENTD_MMGR_DOWNSCALE
        };
        let message = format!( "{}\n{}\n", cmd, scalevalue);

        if let Err(e) = stream.write_all(message.as_bytes()) {
            log::error!("Error writing to stream: {}", e);
            return false;
        }

        log::debug!("Scaling resource upscale: {}, scalevalue: {}", upscale, scalevalue);
        true
    }

    fn parse_command(&self, line: &String) {
        let mut parts = line.trim().split_whitespace();
        if let Some(command) = parts.next() {
            match command {
                "START" => {
                    let pid: u32 = parts.next().unwrap().parse().unwrap();
                    let interval: u64 = parts.next().unwrap().parse().unwrap();
                    {
                        let mut pids_lock = pids.lock().unwrap();
                        pids_lock.entry(pid).or_insert_with(HashMap::new);
                    }
                    println!("START command received for PID {} with interval {}", pid, interval);
                }
                "FN_INIT" => {
                    let pid: u32 = parts.next().unwrap().parse().unwrap();
                    let func_name = parts.next().unwrap().to_string();
                    let upper_threshold: f64 = parts.next().unwrap().parse().unwrap();
                    let lower_threshold: f64 = parts.next().unwrap().parse().unwrap();
                    let spike_count: usize = parts.next().unwrap().parse().unwrap();
                    {
                        let mut pids_lock = pids.lock().unwrap();
                        let pid_entry = pids_lock.entry(pid).or_insert_with(HashMap::new);
                        pid_entry.insert(
                            func_name.clone(),
                            FunctionMetrics {
                                upper_threshold,
                                lower_threshold,
                                spike_count,
                                metrics: VecDeque::new(),
                            },
                        );
                    }
                    println!(
                        "FN_INIT command received for PID {} and function {}",
                        pid, func_name
                    );

                }
                "LOG" => {
                    let pid: u32 = parts.next().unwrap().parse().unwrap();
                    let func_name = parts.next().unwrap().to_string();
                    let metric: f64 = parts.next().unwrap().parse().unwrap();
                    let mut scale_up = false;
                    let mut scale_down = false;
                    {
                        let mut pids_lock = pids.lock().unwrap();
                        if let Some(func_map) = pids_lock.get_mut(&pid) {
                            if let Some(func_metrics) = func_map.get_mut(&func_name) {
                                func_metrics.metrics.push_back(metric);
                                if func_metrics.metrics.len() == func_metrics.spike_count {
                                    if func_metrics.metrics.iter().all(|&m| m > func_metrics.upper_threshold) {
                                        scale_up = true;
                                    } else if func_metrics.metrics.iter().all(|&m| m < func_metrics.lower_threshold) {
                                        scale_down = true;
                                    }
                                    func_metrics.metrics.pop_front();
                                }
                            }
                        }
                    }
                    if scale_up {
                        println!("Scale up command issued for PID {} and function {}", pid, func_name);
                    } else if scale_down {
                        println!("Scale down command issued for PID {} and function {}", pid, func_name);
                    }
                }
                "STOP" => {
                    let pid: u32 = parts.next().unwrap().parse().unwrap();
                    {
                        let mut pids_lock = pids.lock().unwrap();
                        pids_lock.remove(&pid);
                    }
                    println!("STOP command received for PID {}", pid);
                }
                _ => {
                    println!("Unknown command received: {}", cmd);
                }
            }
        }
    }

